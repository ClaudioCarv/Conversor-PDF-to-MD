# Arquivo de Configuração - PDF to Markdown Converter
# Copie este arquivo para .env para personalizar configurações

# Diretórios
INPUT_DIR=input
OUTPUT_DIR=output
LOGS_DIR=logs

# Validação
ENABLE_SPELL_CHECK=true
ENABLE_GRAMMAR_CHECK=true
ENABLE_FIDELITY_CHECK=true

# Language Tool
LANGUAGE_TOOL_LANGUAGE=pt-BR

# Docling - Pipeline
ENABLE_OCR=true
ENABLE_TABLE_DETECTION=true

# Relatórios
GENERATE_TEXT_REPORT=true
GENERATE_JSON_REPORT=false
VERBOSE_LOGGING=true

# Dicionário customizado (palavras técnicas que não devem ser marcadas como erro)
CUSTOM_DICTIONARY=SIAGOV,API,webservice,endpoint,REST,JSON,XML,PDF,OCR
